# Frontend configuration for the standalone Even Hub app.
# Copy this file to `.env.local`. Never commit `.env.local`.

# G2 mic audio streams directly to Deepgram over WebSocket.
VITE_STT_PROVIDER=deepgram

# Deepgram API key used by the browser/WebView client.
# This is suitable for demos and hackathons; production apps should proxy this.
VITE_STT_API_KEY=

# Locale hint for the streaming recognizer.
VITE_STT_LANGUAGE=en-US
