# Frontend configuration for the Even Hub app.
# Copy this file to `.env.local`. Never commit `.env.local`.

# The FastAPI service used for session persistence, export, and non-browser STT.
VITE_API_BASE_URL=http://localhost:8000

# Speech provider for the frontend bridge:
# - browser: Web Speech API fallback, zero-config in supported browsers
# - whisper | deepgram | assemblyai: send PCM chunks to the FastAPI backend for transcription
VITE_STT_PROVIDER=browser

# Optional client-side key if you later wire a direct browser provider.
VITE_STT_API_KEY=

# Locale for browser speech recognition and backend hints.
VITE_STT_LANGUAGE=en-US
