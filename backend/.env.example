# Backend speech provider selection: whisper | deepgram | assemblyai
STT_PROVIDER=whisper
STT_LANGUAGE=en

# Local Whisper / OpenAI-compatible transcription endpoint
WHISPER_API_URL=http://127.0.0.1:8001/v1/audio/transcriptions
WHISPER_MODEL=whisper-1
WHISPER_API_KEY=

# Deepgram prerecorded transcription
DEEPGRAM_API_KEY=
DEEPGRAM_API_URL=https://api.deepgram.com/v1/listen?model=nova-3&smart_format=true

# AssemblyAI upload + transcript polling
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_UPLOAD_URL=https://api.assemblyai.com/v2/upload
ASSEMBLYAI_TRANSCRIPT_URL=https://api.assemblyai.com/v2/transcript
